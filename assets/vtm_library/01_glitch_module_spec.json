{
  "module_id": "VTM-GLITCH",
  "function": "논리적 오류, 데이터 손실 시각화 (System Failure)",
  "trigger_condition": ["Data Integrity Check Failed", "Overload"],
  "color_palette_usage": {
    "primary_error_glow": "#ff6b6b",
    "bg_corruption_depth": "Deep Indigo (Opacity 0.1)",
    "highlight_data_line": "Aged Gold (#c9a544)"
  },
  "parameters": {
    "severity_level": {"type": "enum", "options": ["LOW", "MEDIUM", "HIGH"], "default": "MEDIUM"},
    "glitch_duration_sec": {"type": "float", "min": 0.1, "max": 1.5, "default": 0.5},
    "corruption_pattern": {"type": "enum", "options": ["SCANLINE", "PIXEL-SHIFT", "STATIC"], "default": "SCANLINE"},
    "decay_rate": {"type": "float", "min": 0.1, "max": 2.0, "default": 1.0}
  },
  "developer_notes": "파라미터 기반으로 노이즈 발생률과 화면 왜곡(Warping) 정도를 제어해야 함."
}
